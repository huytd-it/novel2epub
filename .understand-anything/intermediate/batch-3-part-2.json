    {"id": "function:novel2epub/pipeline.py:_require_chapter","type": "function","name": "_require_chapter","filePath": "novel2epub/pipeline.py","lineRange": [686,694],"summary": "Loads a manifest and looks up a chapter by index, raising RuntimeError if not found.","tags": ["utility","validation"],"complexity": "simple"},
