    {"id": "function:novel2epub/pipeline.py:step_build","type": "function","name": "step_build","filePath": "novel2epub/pipeline.py","lineRange": [769,808],"summary": "Pipeline step: builds the EPUB by reading all translated chapters, applying glossary footnote annotations, and invoking the epub_builder to generate the output file.","tags": ["pipeline","epub","build","step"],"complexity": "moderate"},
